From 351425e81a59c89407e36e43e8b79b7c7a82c2c0 Mon Sep 17 00:00:00 2001
From: Garrett Brown <themagnificentmrb@gmail.com>
Date: Fri, 29 May 2026 16:49:18 -0700
Subject: [PATCH] Default CPU compatibility to "normal" on x86_64

Remove the x86_64-specific default of memory and use normal for all targets
in core options initialization.
---
 libretro/libretro-core.c | 4 ----
 1 file changed, 4 deletions(-)

diff --git a/libretro/libretro-core.c b/libretro/libretro-core.c
index 24c89346..5cc02e58 100644
--- a/libretro/libretro-core.c
+++ b/libretro/libretro-core.c
@@ -1099,11 +1099,7 @@ static void retro_set_core_options()
             { "exact", "Cycle-exact" },
             { NULL, NULL },
          },
-#if defined(__x86_64__)
-         "exact"
-#else
          "normal"
-#endif
       },
       {
          "puae_autoloadfastforward",
-- 
